generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AudienceScope {
  GLOBAL
  COUNTRY
  SELECTED_COUNTRIES
  PRIVATE
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
  DELETED
}

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  passwordHash    String
  role            UserRole   @default(USER)
  status          UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  profile       UserProfile?
  languagePairs UserLanguagePair[]
  authSessions  AuthSession[]
}

model UserProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  displayName          String?
  countryCode          String?
  interfaceLanguage    String   @default("az")
  activeLanguagePairId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  country            Country?      @relation(fields: [countryCode], references: [code])
  activeLanguagePair LanguagePair? @relation("ActiveLanguagePair", fields: [activeLanguagePairId], references: [id])
}

model UserLanguagePair {
  id             String     @id @default(cuid())
  userId         String
  languagePairId String
  isLearning     Boolean    @default(true)
  targetCefrLevel CefrLevel?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  languagePair LanguagePair @relation(fields: [languagePairId], references: [id], onDelete: Cascade)

  @@unique([userId, languagePairId])
}

model AuthSession {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Country {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  emoji     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profiles UserProfile[]
}

model Language {
  id         String   @id @default(cuid())
  code       String   @unique
  name       String
  nativeName String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sourcePairs LanguagePair[] @relation("SourceLanguage")
  targetPairs LanguagePair[] @relation("TargetLanguage")
}

model LanguagePair {
  id               String   @id @default(cuid())
  sourceLanguageId String
  targetLanguageId String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sourceLanguage Language @relation("SourceLanguage", fields: [sourceLanguageId], references: [id])
  targetLanguage Language @relation("TargetLanguage", fields: [targetLanguageId], references: [id])

  activeProfiles    UserProfile[]      @relation("ActiveLanguagePair")
  userLanguagePairs UserLanguagePair[]

  @@unique([sourceLanguageId, targetLanguageId])
}